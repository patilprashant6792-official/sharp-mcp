{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MCP.Core.Services.NuGetService": "Information"
    }
  },
  
    "Redis": {
      "ConnectionString": "localhost:6379",
      "AbortOnConnectFail": true,
      "ConnectTimeout": 3000,
      "SyncTimeout": 3000,
      "AsyncTimeout": 5000,
      "ConnectRetry": 2,
      "KeepAlive": 60,
      "DefaultDatabase": 0,
      "ReconnectRetryBaseDelay": 5000
    }
  ,
  "ProjectMappings": {
    "Projects": {
      "LocalMcpServer": {
        "Path": "C:\\Users\\Aumni\\source\\repos\\dotnet-mcp-server\\LocalMcpServer",
        "Description": "prashant's local mcp server"
      },
      "RisingTideTradeCapture": {
        "Path": "C:\\Users\\Aumni\\source\\repos\\RisingTideTradeCaptureMCP",
        "Description": "Trades API"
      },
      "RisingTideAPI": {
        "Path": "C:\\Users\\Aumni\\source\\repos\\RisingTideAPI",
        "Description": "Main API"
      }
    }
  },
  "AllowedHosts": "*",
  "NuGetService": {
    "MaxPackageSizeBytes": 104857600,
    "MaxConcurrentOperations": 5,
    "OperationTimeout": "00:02:00",
    "MaxAssembliesPerPackage": 50,
    "DownloadTimeout": "00:00:30",
    "MaxPackageIdLength": 200,
    "SupportedFrameworks": [
      "net8.0",
      "net7.0",
      "net6.0",
      "net5.0",
      "netstandard2.1",
      "netstandard2.0",
      "netstandard1.6"
    ],
    "FrameworkPriority": [
      "net8.0",
      "net7.0",
      "net6.0",
      "netstandard2.1",
      "netstandard2.0"
    ],
    "EnableTempCleanup": true,
    "Retry": {
      "MaxRetries": 3,
      "InitialDelay": "00:00:00.100",
      "MaxDelay": "00:00:05"
    }
  }
}